<%- include('partials/header') %>

<style>
  .form-container {
    background-color: var(--card-bg);
    padding: 2rem;
    border-radius: 12px;
    max-width: 700px;
    margin: auto;
  }
  .form-group {
    margin-bottom: 1.5rem;
  }
  label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 500;
    color: var(--text-secondary);
  }
  input, textarea {
    width: 100%;
    padding: 0.8rem 1rem;
    border-radius: 8px;
    border: 1px solid #4b5563;
    background-color: var(--sidebar-bg);
    color: var(--text-main);
    font-size: 1rem;
    font-family: 'Inter', sans-serif;
  }
  input:focus, textarea:focus {
    outline: none;
    border-color: var(--accent-color);
  }
  .btn {
    display: inline-block;
    padding: 0.8rem 1.5rem;
    background-color: var(--accent-color);
    color: #fff;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 500;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .btn:hover {
    opacity: 0.9;
  }
</style>

<div class="page-header">
  <h2>Business Details</h2>
</div>

<div class="form-container">
  <form action="/business-details" method="POST">
    <div class="form-group">
      <label for="businessName">Business Name</label>
      <input type="text" id="businessName" name="businessName" value="<%= businessSetup.businessName || '' %>" required>
    </div>
    <div class="form-group">
      <label for="address">Address</label>
      <input type="text" id="address" name="address" value="<%= businessSetup.address || '' %>">
    </div>
    <div class="form-group">
      <label for="phone">Phone Number</label>
      <input type="text" id="phone" name="phone" value="<%= businessSetup.phone || '' %>">
    </div>
    <div class="form-group">
      <label for="receiptFooter">Receipt Footer</label>
      <textarea id="receiptFooter" name="receiptFooter" rows="3"><%= businessSetup.receiptFooter || '' %></textarea>
    </div>
    <button type="submit" class="btn">Save Details</button>
  </form>
</div>

<%- include('partials/footer') %>
