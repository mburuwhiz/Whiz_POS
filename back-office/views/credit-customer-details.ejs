<%- include('partials/header') %>

<style>
  .customer-header {
    margin-bottom: 2rem;
  }
  .customer-header h2 {
    font-size: 1.8rem;
    font-weight: 600;
  }
  .customer-header p {
    color: var(--text-secondary);
  }
  .table-container {
    background-color: var(--card-bg);
    padding: 1.5rem;
    border-radius: 12px;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    color: var(--text-main);
  }
  th, td {
    padding: 1rem 0.5rem;
    text-align: left;
    border-bottom: 1px solid #4b5563;
  }
  th {
    font-weight: 600;
    color: var(--text-secondary);
  }
  .payment-form {
    display: flex;
    align-items: center;
  }
  .payment-form input {
    width: 120px;
    padding: 0.5rem;
    border-radius: 6px;
    border: 1px solid #4b5563;
    background-color: var(--sidebar-bg);
    color: var(--text-main);
    margin-right: 0.5rem;
  }
  .payment-form button {
    padding: 0.5rem 1rem;
    background-color: var(--accent-color);
    color: #fff;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .payment-form button:hover {
    opacity: 0.9;
  }
  .status {
    padding: 0.2rem 0.5rem;
    border-radius: 12px;
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: capitalize;
  }
  .status-paid { background-color: #10b981; color: #fff; }
  .status-unpaid { background-color: #ef4444; color: #fff; }
  .status-partially-paid { background-color: #f59e0b; color: #fff; }
</style>

<div class="customer-header">
  <h2><%= customer.name %></h2>
  <p>Phone: <%= customer.phone || 'N/A' %></p>
</div>

<div class="table-container">
  <h3>Credit Sales History</h3>
  <table>
    <thead>
      <tr>
        <th>Transaction ID</th>
        <th>Total Amount</th>
        <th>Paid Amount</th>
        <th>Balance</th>
        <th>Status</th>
        <th>Add Payment</th>
      </tr>
    </thead>
    <tbody>
      <% customer.creditSales.forEach(sale => { %>
        <tr>
          <td><%= sale.transaction ? sale.transaction.id.toString().slice(-8) : 'N/A' %></td>
          <td>Ksh. <%= sale.amount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
          <td>Ksh. <%= sale.paidAmount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
          <td>Ksh. <%= (sale.amount - sale.paidAmount).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
          <td><span class="status status-<%= sale.status.replace('_', '-') %>"><%= sale.status %></span></td>
          <td>
            <% if (sale.status !== 'paid') { %>
              <form class="payment-form" action="/credit-customers/<%= customer.id %>/add-payment" method="POST">
                <input type="hidden" name="saleId" value="<%= sale.id %>">
                <input type="number" name="amount" placeholder="Amount" step="0.01" required>
                <button type="submit">Pay</button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<%- include('partials/footer') %>
