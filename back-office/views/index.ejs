<%- include('partials/header') %>

<div class="page-header">
  <h2>Dashboard</h2>
</div>

<div class="card">
  <h3>Today's Sales</h3>
  <p style="font-size: 2rem; font-weight: 700; color: var(--accent-color);">Ksh. <%= dailySales.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></p>
</div>

<div class="card">
  <h3>Top Selling Products Today</h3>
  <% if (topSellingProducts.length > 0) { %>
    <ul style="list-style: none;">
      <% topSellingProducts.forEach(product => { %>
        <li style="padding: 0.5rem 0; border-bottom: 1px solid #4b5563;">
          <span style="font-weight: 500;"><%= product.name %></span> -
          <span style="color: var(--text-secondary);"><%= product.sales %> sold</span>
        </li>
      <% }) %>
    </ul>
  <% } else { %>
    <p style="color: var(--text-secondary);">No sales recorded yet today.</p>
  <% } %>
</div>

<%- include('partials/footer') %>
