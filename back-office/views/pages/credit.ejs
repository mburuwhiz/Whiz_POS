<div class="mb-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
        <h2 class="text-2xl font-bold text-gray-900">Credit Management</h2>
        <p class="text-sm text-gray-500">Track customer debts and payments.</p>
    </div>
    <div class="flex gap-2">
        <button class="flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 shadow-sm shadow-blue-600/20 transition-colors">
            <i data-lucide="user-plus" class="w-4 h-4"></i>
            Add Customer
        </button>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
        <p class="text-sm font-medium text-gray-500 mb-1">Total Outstanding Credit</p>
        <h3 class="text-2xl font-bold text-gray-900">Ksh. <%= customers.reduce((sum, c) => sum + c.balance, 0).toLocaleString() %></h3>
    </div>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
            <thead class="bg-gray-50 border-b border-gray-100">
                <tr>
                    <th class="px-6 py-4 font-medium text-gray-500">Customer Name</th>
                    <th class="px-6 py-4 font-medium text-gray-500">Phone</th>
                    <th class="px-6 py-4 font-medium text-gray-500 text-right">Total Credit</th>
                    <th class="px-6 py-4 font-medium text-gray-500 text-right">Paid Amount</th>
                    <th class="px-6 py-4 font-medium text-gray-500 text-right">Balance</th>
                    <th class="px-6 py-4 font-medium text-gray-500 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                <% if (customers && customers.length > 0) { %>
                    <% customers.forEach(customer => { %>
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-6 py-4 font-medium text-gray-900"><%= customer.name %></td>
                        <td class="px-6 py-4 text-gray-500"><%= customer.phone || 'N/A' %></td>
                        <td class="px-6 py-4 text-right text-gray-900">Ksh. <%= customer.totalCredit.toLocaleString() %></td>
                        <td class="px-6 py-4 text-right text-green-600">Ksh. <%= customer.paidAmount.toLocaleString() %></td>
                        <td class="px-6 py-4 text-right font-bold <%= customer.balance > 0 ? 'text-red-600' : 'text-gray-900' %>">
                            Ksh. <%= customer.balance.toLocaleString() %>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <button class="text-blue-600 hover:text-blue-700 font-medium text-xs mr-2">Record Payment</button>
                            <button class="text-gray-400 hover:text-blue-600 transition-colors">
                                <i data-lucide="eye" class="w-4 h-4"></i>
                            </button>
                        </td>
                    </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="6" class="px-6 py-4 text-center text-gray-500">No credit customers found.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>
