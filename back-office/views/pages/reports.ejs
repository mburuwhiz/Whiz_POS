<div class="mb-6">
    <h2 class="text-2xl font-bold text-gray-900">Reports</h2>
    <p class="text-sm text-gray-500">Generate and view business reports.</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <!-- Daily Closing Report -->
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-all group cursor-pointer">
        <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
            <i data-lucide="file-text" class="w-6 h-6"></i>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">Daily Closing</h3>
        <p class="text-sm text-gray-500 mb-4">End-of-day summaries including total sales, cash in hand, and expenses.</p>
        <button class="text-blue-600 font-medium text-sm flex items-center gap-1 group-hover:gap-2 transition-all">
            Generate Report <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </button>
    </div>

    <!-- Sales Summary -->
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-all group cursor-pointer">
        <div class="w-12 h-12 bg-green-50 text-green-600 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
            <i data-lucide="bar-chart-3" class="w-6 h-6"></i>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">Sales Summary</h3>
        <p class="text-sm text-gray-500 mb-4">Detailed breakdown of sales by product, category, or cashier over time.</p>
        <button class="text-green-600 font-medium text-sm flex items-center gap-1 group-hover:gap-2 transition-all">
            View Analytics <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </button>
    </div>

    <!-- Inventory Report -->
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-all group cursor-pointer">
        <div class="w-12 h-12 bg-purple-50 text-purple-600 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
            <i data-lucide="package" class="w-6 h-6"></i>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">Stock Report</h3>
        <p class="text-sm text-gray-500 mb-4">Current stock levels, low stock alerts, and inventory valuation.</p>
        <button class="text-purple-600 font-medium text-sm flex items-center gap-1 group-hover:gap-2 transition-all">
            View Stock <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </button>
    </div>

    <!-- Expense Report -->
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-all group cursor-pointer">
        <div class="w-12 h-12 bg-red-50 text-red-600 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
            <i data-lucide="receipt" class="w-6 h-6"></i>
        </div>
        <h3 class="text-lg font-bold text-gray-900 mb-2">Expense Report</h3>
        <p class="text-sm text-gray-500 mb-4">Analysis of business spending and operational costs.</p>
        <button class="text-red-600 font-medium text-sm flex items-center gap-1 group-hover:gap-2 transition-all">
            View Expenses <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </button>
    </div>
</div>
