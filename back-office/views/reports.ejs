<%- include('partials/header') %>

<style>
  .table-container {
    background-color: var(--card-bg);
    padding: 1.5rem;
    border-radius: 12px;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    color: var(--text-main);
  }
  th, td {
    padding: 1rem 0.5rem;
    text-align: left;
    border-bottom: 1px solid #4b5563;
  }
  th {
    font-weight: 600;
    color: var(--text-secondary);
  }
  .actions a, .actions button {
    color: var(--accent-color);
    background: none;
    border: none;
    cursor: pointer;
    text-decoration: none;
    margin-right: 1rem;
    transition: all 0.2s ease;
  }
  .actions a:hover, .actions button:hover {
    opacity: 0.8;
  }
  .filter-form {
    margin-bottom: 1.5rem;
    display: flex;
    gap: 1rem;
    align-items: center;
  }
  .filter-form select, .filter-form button {
    padding: 0.5rem 1rem;
    border-radius: 8px;
    border: 1px solid #4b5563;
    background-color: var(--sidebar-bg);
    color: var(--text-main);
  }
  .filter-form button {
    background-color: var(--accent-color);
    border: none;
  }
</style>

<div class="page-header">
  <h2>Transaction Reports</h2>
</div>

<div class="card">
  <form action="/reports" method="GET" class="filter-form">
    <label for="filter">Filter by:</label>
    <select name="filter" id="filter">
      <option value="all" <%= filter === 'all' ? 'selected' : '' %>>All Sales</option>
      <option value="credit" <%= filter === 'credit' ? 'selected' : '' %>>Credit Sales</option>
    </select>
    <button type="submit">Filter</button>
  </form>
</div>

<div class="table-container">
  <table>
    <thead>
      <tr>
        <th>Transaction ID</th>
        <th>Date</th>
        <th>Cashier</th>
        <th>Total</th>
        <th>Payment Method</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% transactions.forEach(txn => { %>
        <tr>
          <td><%= txn.id.toString().slice(-8) %></td>
          <td><%= new Date(txn.createdAt).toLocaleString() %></td>
          <td><%= txn.cashier %></td>
          <td>Ksh. <%= txn.total.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
          <td><%= txn.paymentMethod %></td>
          <td class="actions">
            <form action="/reprint/<%= txn.id %>" method="POST" style="display:inline;">
              <button type="submit"><i data-feather="printer"></i></button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<%- include('partials/footer') %>
