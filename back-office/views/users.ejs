<%- include('partials/header') %>

<style>
  .table-container {
    background-color: var(--card-bg);
    padding: 1.5rem;
    border-radius: 12px;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    color: var(--text-main);
  }
  th, td {
    padding: 1rem 0.5rem;
    text-align: left;
    border-bottom: 1px solid #4b5563;
  }
  th {
    font-weight: 600;
    color: var(--text-secondary);
  }
  .actions a, .actions button {
    color: var(--accent-color);
    background: none;
    border: none;
    cursor: pointer;
    text-decoration: none;
    margin-right: 1rem;
    transition: all 0.2s ease;
  }
  .actions a:hover, .actions button:hover {
    opacity: 0.8;
  }
  .btn {
    display: inline-block;
    padding: 0.6rem 1.2rem;
    background-color: var(--accent-color);
    color: #fff;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  .btn:hover {
    opacity: 0.9;
  }
</style>

<div class="page-header">
  <h2>Manage Users</h2>
  <a href="/users/add" class="btn">Add User</a>
</div>

<div class="table-container">
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Role</th>
        <th>PIN</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(user => { %>
        <tr>
          <td><%= user.name %></td>
          <td><%= user.email %></td>
          <td><%= user.role %></td>
          <td><%= user.pin %></td>
          <td class="actions">
            <a href="/users/edit/<%= user.id %>"><i data-feather="edit-2"></i></a>
            <form action="/users/delete/<%= user.id %>" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this user?');">
              <button type="submit" style="color: #ef4444;"><i data-feather="trash-2"></i></button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<%- include('partials/footer') %>
